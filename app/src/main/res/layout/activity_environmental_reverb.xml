<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/reverbBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Environmental Reverb"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:paddingStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/reverbScrollContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp">

            <!-- Reverb Level master card — controls roomLevelDb, the
                 master output of the whole reverb effect (= early
                 reflections + decay tail together). Lives at the top
                 of the screen as the most fundamental knob. -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Room Level"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/reverbMasterLevelSlider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="-90"
                        android:valueTo="0"
                        android:value="-10"
                        app:labelBehavior="gone" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/reverbMasterLevelText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberSigned|numberDecimal"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:imeOptions="actionDone" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reverb amplitude IR — visualizer at the top, then a
                 click-to-expand "Reverb Parameters" panel below it,
                 all inside ONE outlined card so the dropdown reads
                 as part of the graph card. -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FF1A1A1A"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FF333333">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.bearinmind.equalizer314.ui.ReverbVisualizerView
                        android:id="@+id/reverbVisualizer"
                        android:layout_width="match_parent"
                        android:layout_height="286dp" />

                    <!-- Reverb Parameters wrapped in a nested
                         MaterialCardView so a rounded outline wraps
                         around just the params section. The card
                         spans the full width (no left/right
                         indentation) and its bottom edge sits on
                         the outer card's bottom edge — only its
                         TOP corners are rounded, creating a clean
                         "rounded card" cap above the dropdown. -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#FF1A1A1A"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#FF333333">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/graphParamsHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reverb Parameters"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="#FFCCCCCC" />

                        <ImageView
                            android:id="@+id/graphParamsChevron"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="90"
                            android:contentDescription="Expand reverb parameters"
                            app:tint="#FFCCCCCC" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/graphParamsContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="12dp"
                        android:visibility="gone">

                        <!-- Pre-delay (Reflections Delay) -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                                android:text="Pre-delay (ms)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="#FFAAAAAA" />
                            <com.google.android.material.slider.Slider android:id="@+id/reverbReflectDelaySlider"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:valueFrom="0" android:valueTo="300" android:value="7"
                                app:labelBehavior="gone" />
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                                android:layout_height="wrap_content" android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbReflectDelayText"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" android:textSize="12sp"
                                    android:gravity="center" android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Early Reflections (Reflections Level) -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                                android:text="Early Refl (dB)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="#FFAAAAAA" />
                            <com.google.android.material.slider.Slider android:id="@+id/reverbReflectLevelSlider"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:valueFrom="-90" android:valueTo="10" android:value="-10"
                                app:labelBehavior="gone" />
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                                android:layout_height="wrap_content" android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbReflectLevelText"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="numberDecimal|numberSigned" android:textSize="12sp"
                                    android:gravity="center" android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Reverb Delay -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                                android:text="Reverb Delay (ms)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="#FFAAAAAA" />
                            <com.google.android.material.slider.Slider android:id="@+id/reverbDelaySlider"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:valueFrom="0" android:valueTo="100" android:value="11"
                                app:labelBehavior="gone" />
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                                android:layout_height="wrap_content" android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbDelayText"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" android:textSize="12sp"
                                    android:gravity="center" android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Decay -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                                android:text="Decay (ms)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="#FFAAAAAA" />
                            <com.google.android.material.slider.Slider android:id="@+id/reverbDecayTimeSlider"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:valueFrom="100" android:valueTo="20000" android:value="1490" app:labelBehavior="gone" />
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                                android:layout_height="wrap_content" android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbDecayTimeText"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" android:textSize="12sp"
                                    android:gravity="center" android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- HF Level (room HF level) — new slider; mirrors
                             the HF Level dot in the visualizer. -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                                android:text="HF Level (dB)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="#FFAAAAAA" />
                            <com.google.android.material.slider.Slider android:id="@+id/reverbRoomHFLevelSlider"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:valueFrom="-90" android:valueTo="0" android:value="0"
                                app:labelBehavior="gone" />
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                                android:layout_height="wrap_content" android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbRoomHFLevelText"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="numberDecimal|numberSigned" android:textSize="12sp"
                                    android:gravity="center" android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- HF Damping (Decay HF Ratio) -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                                android:text="HF Damping" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="#FFAAAAAA" />
                            <com.google.android.material.slider.Slider android:id="@+id/reverbDecayHfSlider"
                                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:valueFrom="0.10" android:valueTo="2.00" android:value="0.83"
                                app:labelBehavior="gone" />
                            <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                                android:layout_height="wrap_content" android:layout_marginStart="4dp"
                                app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                                app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                                <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbDecayHfText"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:inputType="numberDecimal" android:textSize="12sp"
                                    android:gravity="center" android:imeOptions="actionDone" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Diffusion/Density X/Y graph (70%) + Diff/Dens column
                 sliders (30%) — mirrors the Limiter screen's waveform +
                 ceiling/GR side-by-side layout. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="0.7"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#FF1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FF333333">

                    <com.bearinmind.equalizer314.ui.DiffusionDensityView
                        android:id="@+id/reverbDiffusionDensity"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="0.3"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#FF1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FF333333">

                    <com.bearinmind.equalizer314.ui.DiffusionDensityColumnsView
                        android:id="@+id/reverbDiffusionDensityColumns"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Reverb Level -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                            android:text="Reverb (dB)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/reverbLevelSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="-90" android:valueTo="20" android:value="-26"
                            app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbLevelText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal|numberSigned" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Room Level -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                            android:text="Room (dB)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/reverbRoomSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="-90" android:valueTo="0" android:value="-10"
                            app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbRoomText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal|numberSigned" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Diffusion -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                            android:text="Diffusion (%)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/reverbDiffusionSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="0" android:valueTo="100" android:value="100"
                            app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbDiffusionText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Density -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content"
                            android:text="Density (%)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/reverbDensitySlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="0" android:valueTo="100" android:value="100"
                            app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/reverbDensityText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
