<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mbcRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/mbcBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Multiband Compression"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:paddingStart="8dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/mbcMasterSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- EQ Graph -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.bearinmind.equalizer314.ui.EqGraphView
                android:id="@+id/mbcGraphView"
                android:layout_width="match_parent"
                android:layout_height="220dp" />

            <com.bearinmind.equalizer314.ui.GrTraceView
                android:id="@+id/mbcGrTraceView"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:visibility="gone" />

            <!-- Graph mode toggles (top-left, same size/style as spectrum toggle) -->
            <LinearLayout
                android:id="@+id/mbcGraphModeToggleGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mbcGraphModeFreq"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_graph_freq"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@null"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MbcEqButton"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp"
                    android:contentDescription="Frequency view" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mbcGraphModeTime"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_graph_time"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="@null"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MbcGrButton"
                    app:strokeColor="#FF444444"
                    app:strokeWidth="1dp"
                    android:contentDescription="GR trace view" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mbcVisualizerToggle"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="3dp"
                app:icon="@drawable/ic_spectrum"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="@null"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.SpectrumButton"
                app:strokeColor="#FF444444"
                app:strokeWidth="1dp"
                android:contentDescription="Toggle visualizer" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Band selector tabs -->
    <LinearLayout
        android:id="@+id/mbcBandTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp" />

    <!-- Scrollable band parameters -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Band Enable + Frequency -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/mbcBandTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|center_vertical"
                            android:text="Band 1"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/mbcBandColorBox"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="\u2014"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/mbcBandSwitch"
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical" />
                    </FrameLayout>

                    <!-- Cutoff Frequency -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Cutoff (Hz)"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/mbcCutoffSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="20"
                            android:valueTo="20000"
                            android:value="1000"
                            app:labelBehavior="gone" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/mbcCutoffText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textSize="12sp"
                                android:text="1000"
                                android:gravity="center"
                                android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Pre-Gain -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Pre-Gain (dB)"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/mbcPreGainSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="-12"
                            android:valueTo="12"
                            android:value="0"
                            app:labelBehavior="gone" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/mbcPreGainText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal|numberSigned"
                                android:textSize="12sp"
                                android:text="0.0"
                                android:gravity="center"
                                android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Post-Gain -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:text="Post-Gain (dB)"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/mbcPostGainSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="-30"
                            android:valueTo="30"
                            android:value="0"
                            app:labelBehavior="gone" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="64dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/mbcPostGainText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal|numberSigned"
                                android:textSize="12sp"
                                android:text="0.0"
                                android:gravity="center"
                                android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- RANGE FEATURE COMMENTED OUT - Range UI hidden, data still saved/loaded in code -->
                    <!--
