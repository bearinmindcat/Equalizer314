<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/limiterRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/limiterBackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Limiter"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:paddingStart="8dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/limiterMasterSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Waveform (70%) + Ceiling/GR (30%) side by side -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Waveform graph card — 70% -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="0.7"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#FF1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FF333333">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <com.bearinmind.equalizer314.ui.LimiterWaveformView
                            android:id="@+id/limiterWaveform"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/limiterVisualizerToggle"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="3dp"
                            app:icon="@drawable/ic_spectrum"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconTint="@null"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.SpectrumButton"
                            app:strokeColor="#FF444444"
                            app:strokeWidth="1dp"
                            android:contentDescription="Toggle visualizer" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ceiling + GR columns card — 30% -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="220dp"
                    android:layout_weight="0.3"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#FF1A1A1A"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FF333333">

                    <com.bearinmind.equalizer314.ui.LimiterCeilingView
                        android:id="@+id/limiterCeilingView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- All limiter controls in one card (MBC style) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Threshold -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                            android:text="Thresh (dB)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/limiterThresholdSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="-30" android:valueTo="0" android:value="0" app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/limiterThresholdText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal|numberSigned" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Ratio -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                            android:text="Ratio (X:1)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/limiterRatioSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="1" android:valueTo="50" android:value="10" app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/limiterRatioText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Attack -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                            android:text="Attack (ms)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/limiterAttackSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="0.01" android:valueTo="100" android:value="1" app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/limiterAttackText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Release -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="4dp">
                        <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                            android:text="Release (ms)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/limiterReleaseSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="1" android:valueTo="500" android:value="50" app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/limiterReleaseText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Post Gain -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="96dp" android:layout_height="wrap_content"
                            android:text="Post Gain (dB)" android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                        <com.google.android.material.slider.Slider android:id="@+id/limiterPostGainSlider"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:valueFrom="-12" android:valueTo="12" android:value="0" app:labelBehavior="gone" />
                        <com.google.android.material.textfield.TextInputLayout android:layout_width="64dp"
                            android:layout_height="wrap_content" android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp" app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp" app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">
                            <com.google.android.material.textfield.TextInputEditText android:id="@+id/limiterPostGainText"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:inputType="numberDecimal|numberSigned" android:textSize="12sp"
                                android:gravity="center" android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">
        <include layout="@layout/bottom_nav" />
    </FrameLayout>
</LinearLayout>
