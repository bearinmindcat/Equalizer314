<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Page content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ========== EQ Page ========== -->
        <ScrollView
            android:id="@+id/pageEq"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- EQ Mode Selector -->
                <LinearLayout
                    android:id="@+id/modeSelectorGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/modeParametricBtn"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Parametric"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/modeGraphicBtn"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="Graphic"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/modeTableBtn"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Table"
                        android:textSize="12sp"
                        app:cornerRadius="12dp" />
                </LinearLayout>

                <!-- EQ Graph Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <com.bearinmind.equalizer314.ui.EqGraphView
                        android:id="@+id/eqGraphView"
                        android:layout_width="match_parent"
                        android:layout_height="280dp" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Per-band on/off toggles -->
                <LinearLayout
                    android:id="@+id/bandToggleGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center" />

                <!-- Triangle indicator pointing up to selected band -->
                <FrameLayout
                    android:id="@+id/triangleIndicatorContainer"
                    android:layout_width="match_parent"
                    android:layout_height="8dp">

                    <View
                        android:id="@+id/triangleIndicator"
                        android:layout_width="20dp"
                        android:layout_height="10dp"
                        android:layout_gravity="start"
                        android:visibility="invisible" />
                </FrameLayout>

                <!-- Graphic EQ Vertical Sliders (visible in GRAPHIC mode only) -->
                <LinearLayout
                    android:id="@+id/graphicSlidersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:visibility="gone" />

                <!-- EQ Controls Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/parametricControlsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Filter Type Buttons -->
                        <LinearLayout
                            android:id="@+id/filterTypeGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="8dp" />

                        <!-- Band Parameters: linked slider + text input for Hz, dB, Q -->
                        <LinearLayout
                            android:id="@+id/bandInputGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingBottom="4dp">

                            <!-- Hz row -->
                            <LinearLayout
                                android:id="@+id/hzControlRow"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="wrap_content"
                                    android:text="Hz"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/bandHzSlider"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:valueFrom="0"
                                    android:valueTo="1000"
                                    android:value="500"
                                    app:labelBehavior="gone" />

                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    app:boxCornerRadiusTopStart="8dp"
                                    app:boxCornerRadiusTopEnd="8dp"
                                    app:boxCornerRadiusBottomStart="8dp"
                                    app:boxCornerRadiusBottomEnd="8dp"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/bandHzInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="numberDecimal"
                                        android:textSize="12sp"
                                        android:imeOptions="actionDone" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                            <!-- dB row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="28dp"
                                    android:layout_height="wrap_content"
                                    android:text="dB"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/bandDbSlider"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:valueFrom="-12"
                                    android:valueTo="12"
                                    android:value="0"
                                    app:labelBehavior="gone" />

                                <com.google.android.material.textfield.TextInputLayout
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    app:boxCornerRadiusTopStart="8dp"
                                    app:boxCornerRadiusTopEnd="8dp"
                                    app:boxCornerRadiusBottomStart="8dp"
                                    app:boxCornerRadiusBottomEnd="8dp"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/bandDbInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="numberDecimal|numberSigned"
                                        android:textSize="12sp"
                                        android:imeOptions="actionDone" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                            <!-- Q row -->
                            <LinearLayout
                                android:id="@+id/qControlGroup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/qValueText"
                                    android:layout_width="28dp"
                                    android:layout_height="wrap_content"
                                    android:text="Q"
                                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                    android:textColor="?attr/colorOnSurfaceVariant" />

                                <com.google.android.material.slider.Slider
                                    android:id="@+id/qSlider"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:valueFrom="0.1"
                                    android:valueTo="12.0"
                                    android:value="0.71"
                                    app:labelBehavior="gone" />

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/bandQInputLayout"
                                    android:layout_width="80dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    app:boxCornerRadiusTopStart="8dp"
                                    app:boxCornerRadiusTopEnd="8dp"
                                    app:boxCornerRadiusBottomStart="8dp"
                                    app:boxCornerRadiusBottomEnd="8dp"
                                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/bandQInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:inputType="numberDecimal"
                                        android:textSize="12sp"
                                        android:imeOptions="actionDone" />
                                </com.google.android.material.textfield.TextInputLayout>
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Typed EQ Table (visible in TYPED mode only) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/typedEqTableCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp">

                        <!-- Header row pinned to top -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="0.5"
                                android:layout_marginEnd="4dp" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:text="Hz"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:text="dB"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Q"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Band rows centered vertically in full card -->
                        <LinearLayout
                            android:id="@+id/typedEqRowContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:orientation="vertical" />

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- DP Band Count Card (visible in DP/Session modes) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dpBandCountGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="DP"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <com.google.android.material.slider.Slider
                            android:id="@+id/dpBandCountSlider"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:valueFrom="5"
                            android:valueTo="128"
                            android:value="31"
                            app:labelBehavior="gone" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            app:boxCornerRadiusTopStart="8dp"
                            app:boxCornerRadiusTopEnd="8dp"
                            app:boxCornerRadiusBottomStart="8dp"
                            app:boxCornerRadiusBottomEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/dpBandCountText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textSize="12sp"
                                android:text="31"
                                android:gravity="center"
                                android:imeOptions="actionDone" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

        <!-- ========== Settings Page ========== -->
        <ScrollView
            android:id="@+id/pageSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                    android:textColor="?attr/colorPrimary"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp" />

                <!-- Processing Mode Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Controls"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/colorOnSurface"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="(ill add shit here later)"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:paddingBottom="8dp" />

                        <!-- Hidden views kept for code references -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/powerButton"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />
                        <TextView
                            android:id="@+id/statusText"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />
                        <TextView
                            android:id="@+id/modeDescriptionText"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />

                        <!-- Hidden views kept for code references -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/eqToggleButton"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/presetMenuLayout"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone"
                            style="@style/Widget.Material3.TextInputLayout.FilledBox.ExposedDropdownMenu">
                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:id="@+id/presetSpinner"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- Bottom Bar (JamesDSP style: settings | power FAB | presets) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Bar background -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="?attr/colorSurfaceContainerHigh"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- EQ button (left) -->
            <ImageButton
                android:id="@+id/navPresetsButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_nav_equalizer"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="EQ"
                android:scaleType="centerInside"
                app:tint="?attr/colorOnSurface" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Settings button (right) -->
            <ImageButton
                android:id="@+id/navSettingsButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_nav_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:scaleType="centerInside"
                app:tint="?attr/colorOnSurface" />

        </LinearLayout>

        <!-- Floating Power FAB (center, raised above bar) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/powerFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="28dp"
            android:src="@drawable/ic_nav_power"
            android:contentDescription="Power"
            app:fabSize="normal"
            app:backgroundTint="?attr/colorPrimaryContainer"
            app:tint="?attr/colorOnPrimaryContainer"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Equalizer314.FAB"
            app:elevation="6dp" />

    </FrameLayout>

</LinearLayout>
