<?xml version="1.0" encoding="utf-8"?>
<!-- Stateful color list pinning the preset dropdown's outlined box to
     `?attr/colorOnSurfaceVariant` regardless of state. Must be stateful (multiple
     items with state attrs) for Material's setBoxStrokeColorStateList to
     fan the same color out to defaultStrokeColor, hoveredStrokeColor and
     focusedStrokeColor. A non-stateful single-item list only overrides
     the focused color and the box still lights up on tap. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="?attr/colorOnSurfaceVariant" />
    <item android:state_pressed="true" android:color="?attr/colorOnSurfaceVariant" />
    <item android:state_focused="true" android:color="?attr/colorOnSurfaceVariant" />
    <item android:state_hovered="true" android:color="?attr/colorOnSurfaceVariant" />
    <item android:color="?attr/colorOnSurfaceVariant" />
</selector>
