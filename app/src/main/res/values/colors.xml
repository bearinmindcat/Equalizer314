<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light-theme filter/band button colors — mirrored from the dark
         values in values-night/colors.xml (same luminance distance from
         the surface, inverted). -->
    <color name="filter_active">#FF7A7A7A</color>
    <color name="filter_active_text">#FFFFFFFF</color>
    <color name="filter_inactive_text">#FF474747</color>
    <color name="filter_outline">#FFBEBEBE</color>

    <!-- Light green used to tint the "Now playing" speaker pulse when
         a row is actively outputting audio. Same Material Green 200
         the MBC band picker uses for its green band. -->
    <color name="pulse_active_green">#FFA5D6A7</color>

    <!-- Light red used to tint the "Now playing" speaker pulse when
         a row is known to us but silent. Same Material Red 200 the
         reset / delete buttons elsewhere in the app use. -->
    <color name="pulse_inactive_red">#FFEF9A9A</color>

    <!-- Light yellow used for the "Not Priority" pill on the pipeline
         cards (Channel Input / Audio Output) when neither scope is
         currently driving the audio. Material Yellow 200, matched
         shade to the Green 200 / Red 200 pair used elsewhere. -->
    <color name="pill_priority_yellow">#FFFFF59D</color>
</resources>
