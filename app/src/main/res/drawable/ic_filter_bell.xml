<?xml version="1.0" encoding="utf-8"?>
<!--
    Filter icon centering rule:
    All filter icons use a 24x24 viewport. To center the graphic in the button:
    1. Bounding box of the path must span X: 1→23, Y: 6→18
    2. This gives a center point of exactly (12, 12) = viewport center
    3. All 5 filter icons (bell, low/high shelf, low/high pass) share this same bounding box
    4. For shelves: both flat line segments must be equal length (6 units each)
    See also: ic_filter_low_shelf.xml, ic_filter_high_shelf.xml, ic_filter_low_pass.xml, ic_filter_high_pass.xml
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="28dp"
    android:height="28dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:pathData="M 1,18 C 5,18 8,6 12,6 C 16,6 19,18 23,18"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>
</vector>
