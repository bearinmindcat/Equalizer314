<?xml version="1.0" encoding="utf-8"?>
<!-- Ripple drawable for the preset dropdown's TextInputLayout.
     Wrapped in an InsetDrawable so the ripple stops at the outline's
     top edge instead of bleeding into the floated "Preset" label area
     above. 4dp lands the ripple top right at the outline top on
     Material3 OutlinedBox — `insetTop=8dp` was too aggressive (left
     a visible gap below the outline) and 0dp lets the ripple bleed
     into the empty space above the outline. The mask's 4dp corner
     radius matches the OutlinedBox default `boxCornerRadius*` so the
     ripple is also clipped to the outline's rounded corners. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetTop="4dp">

    <ripple android:color="?attr/colorControlHighlight">
        <item android:id="@android:id/mask">
            <shape android:shape="rectangle">
                <solid android:color="@android:color/white" />
                <corners android:radius="4dp" />
            </shape>
        </item>
    </ripple>
</inset>
