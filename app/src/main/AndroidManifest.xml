<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- Needed to list installed apps in the Channel Input screen so
         the user can pre-assign EQ presets to apps that have not yet
         broadcast an audio-effect session. Required on API 30+. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Equalizer314"
        tools:targetApi="31">

        <activity
            android:name="com.bearinmind.equalizer314.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Equalizer314"
            android:configChanges="orientation|keyboardHidden|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.bearinmind.equalizer314.MbcActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.LimiterActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.AutoEqActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.TargetCurveActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.MeasurementSelectActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.TargetSelectActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.SpectrumControlActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ExperimentalActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.CustomPresetsActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ChannelSideEqActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ConvertToApoActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.AudioEffectsPipelineActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.AudioOutputActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ChannelInputActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.EnvironmentalReverbActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <service
            android:name="com.bearinmind.equalizer314.audio.EqService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Receives session-open / session-close broadcasts from
             music apps that opt in to the standard Android audio-
             effect control session pattern (Spotify, Poweramp, AIMP,
             etc.). On OPEN we attach a per-session DynamicsProcessing
             with the user's bound preset; on CLOSE we release it. -->
        <receiver
            android:name="com.bearinmind.equalizer314.audio.AudioSessionReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.media.action.OPEN_AUDIO_EFFECT_CONTROL_SESSION" />
                <action android:name="android.media.action.CLOSE_AUDIO_EFFECT_CONTROL_SESSION" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
