<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Equalizer314"
        tools:targetApi="31">

        <activity
            android:name="com.bearinmind.equalizer314.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Equalizer314"
            android:configChanges="orientation|keyboardHidden|screenSize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.bearinmind.equalizer314.MbcActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.LimiterActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.AutoEqActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.TargetCurveActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.MeasurementSelectActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.TargetSelectActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <activity
            android:name="com.bearinmind.equalizer314.SpectrumControlActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ExperimentalActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.CustomPresetsActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ChannelSideEqActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.ConvertToApoActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />
        <activity
            android:name="com.bearinmind.equalizer314.AudioEffectsPipelineActivity"
            android:exported="false"
            android:theme="@style/Theme.Equalizer314" />

        <service
            android:name="com.bearinmind.equalizer314.audio.EqService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

    </application>

</manifest>
